# Google Apps Script uses Script Properties as the deployed environment.
# Copy these names to Project Settings -> Script properties.

# Required for real outgoing email:
MAIL_PROVIDER=mailapp
EMAIL_MODE=send

# Optional but recommended. Use the deployed Apps Script /exec URL.
APP_BASE_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
MAIL_FROM_NAME=Filmkväll

# Test movie support. Keep disabled in normal use.
TEST_MOVIES_ENABLED=false
TEST_MOVIE_TITLE=Testfilm
